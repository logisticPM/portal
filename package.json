{
  "name": "indigenomics-data-portal-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 tsx scripts/verify.ts",
    "ddb:up": "docker compose up -d",
    "ddb:down": "docker compose down",
    "ddb:create": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 tsx scripts/create-table.ts",
    "ddb:seed": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 tsx scripts/seed.ts",
    "ddb:create:cloud": "cross-env AWS_REGION=us-east-1 tsx scripts/create-table.ts",
    "ddb:seed:cloud": "cross-env AWS_REGION=us-east-1 tsx scripts/seed.ts",
    "survey:create": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 DYNAMO_TABLE=RapSurvey tsx scripts/create-table.ts",
    "survey:seed": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 tsx scripts/seed-survey.ts",
    "survey:create:cloud": "cross-env AWS_REGION=us-east-1 DYNAMO_TABLE=RapSurvey tsx scripts/create-table.ts",
    "survey:seed:cloud": "cross-env AWS_REGION=us-east-1 tsx scripts/seed-survey.ts",
    "seed:sst": "sst shell -- tsx scripts/seed-sst.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.620.0",
    "@aws-sdk/lib-dynamodb": "^3.620.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  }
}
