{
  "name": "indigenomics-data-portal-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 tsx scripts/verify.ts",
    "ddb:up": "docker compose up -d",
    "ddb:down": "docker compose down",
    "ddb:create": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 tsx scripts/create-table.ts",
    "ddb:seed": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 tsx scripts/seed.ts",
    "ddb:create:cloud": "cross-env AWS_REGION=us-east-1 tsx scripts/create-table.ts",
    "ddb:seed:cloud": "cross-env AWS_REGION=us-east-1 tsx scripts/seed.ts",
    "survey:create": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 DYNAMO_TABLE=RapSurvey tsx scripts/create-table.ts",
    "survey:seed": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 tsx scripts/seed-survey.ts",
    "survey:create:cloud": "cross-env AWS_REGION=us-east-1 DYNAMO_TABLE=RapSurvey tsx scripts/create-table.ts",
    "survey:seed:cloud": "cross-env AWS_REGION=us-east-1 tsx scripts/seed-survey.ts",
    "rap:create": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 DYNAMO_TABLE=RapData tsx scripts/create-table.ts",
    "rap:seed": "cross-env DYNAMO_ENDPOINT=http://localhost:8000 REPO_IMPL=dynamo RAP_TABLE=RapData tsx scripts/seed-rap.ts",
    "rap:create:cloud": "cross-env AWS_REGION=us-east-1 DYNAMO_TABLE=RapData tsx scripts/create-table.ts",
    "rap:seed:cloud": "cross-env AWS_REGION=us-east-1 REPO_IMPL=dynamo RAP_TABLE=RapData tsx scripts/seed-rap.ts",
    "seed:sst": "sst shell -- tsx scripts/seed-sst.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-data-automation-runtime": "^3.1077.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1077.0",
    "@aws-sdk/client-dynamodb": "^3.620.0",
    "@aws-sdk/client-lambda": "^3.1078.0",
    "@aws-sdk/client-s3": "^3.1077.0",
    "@aws-sdk/client-textract": "^3.1077.0",
    "@aws-sdk/lib-dynamodb": "^3.620.0",
    "@aws-sdk/s3-request-presigner": "^3.1077.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/heatmap": "^0.99.0",
    "@nivo/network": "^0.99.0",
    "@nivo/treemap": "^0.99.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.0",
    "sst": "^4.15.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0"
  }
}
