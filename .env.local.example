# The demo runs on the in-memory MOCK repo by default — no config needed.
# Switch to DynamoDB once the data group ships repo.dynamo.ts:
#
# REPO_IMPL=dynamo
# AWS_REGION=ca-central-1
# AWS_ACCESS_KEY_ID=...          # server-side only — NEVER prefix with NEXT_PUBLIC_
# AWS_SECRET_ACCESS_KEY=...
# DYNAMO_TABLE=DataPortal
# DYNAMO_ENDPOINT=http://localhost:8000   # DynamoDB Local (Docker)
