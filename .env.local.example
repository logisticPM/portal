# The demo runs on the in-memory MOCK repo by default — no config needed.
# Copy this file to .env.local (gitignored) and uncomment ONE mode below.
#
# ── Mode A: DynamoDB LOCAL (Docker) ────────────────────────────────────────
# Run `npm run ddb:up && npm run ddb:create && npm run ddb:seed` first.
# REPO_IMPL=dynamo
# DYNAMO_ENDPOINT=http://localhost:8000   # the presence of this = LOCAL
# DYNAMO_TABLE=DataPortal
#
# ── Mode B: app local → CLOUD DynamoDB table (real AWS) ─────────────────────
# Uses your ~/.aws/credentials (default profile). NO DYNAMO_ENDPOINT here:
# its ABSENCE is what tells the client to hit real AWS.
# Create the cloud table first: `npm run ddb:create:cloud && npm run ddb:seed:cloud`
# REPO_IMPL=dynamo
# AWS_REGION=us-east-1
# DYNAMO_TABLE=DataPortal
#
# AWS keys are read from ~/.aws (or env). If you ever set them here, they are
# server-side only — NEVER prefix an AWS key with NEXT_PUBLIC_.
